.05)","popupBg":"#FFFFFF","invert":0.8,"iconbg":"#ffffff","additionalAccent":"#42A4FF","additionalAccent30":"rgba(66, 164, 255, 0.3)","additionalAccentHover":"#6BB8FF","additionalAccentPressed":"#1F93FF","success":"#52C78F","additionalSecondary":"#31B8BF","additionalError":"#EC2A2A","raiAudioControlPrimary":"#1C232B","raiAudioProgressBg":"#1EABE9","raiAudioProgressColor":"#F6F6F6","chipsBg":"rgba(0, 0, 0, 0.05)","shade5":"rgba(0, 0, 0, 0.05)","shade10":"rgba(0, 0, 0, 0.1)","shade15":"rgba(0, 0, 0, 0.15)"}}');
      const THEME_ID = new URLSearchParams(document.cookie.replace(/; /g, '&')).get('wdpThemeId') || 'dark2021';
      const activeTheme = THEME[THEME_ID];
      const camelCaseToKebabCase = (string) => {
        if (!string) {
          return string;
        }
        return string.replace(/([A-Z]+)/g, '-$1').toLowerCase();
      }

      let styleText = '[data-pen-theme='+THEME_ID+']{';
      for (const prop in activeTheme) {
        styleText += '--pen-'+camelCaseToKebabCase(prop)+':'+activeTheme[prop]+';';
      }
      styleText += '}';
      const style = document.createElement('style');
      style.innerText = styleText;
      style.id = 'pen-theme-'+THEME_ID;
      document.head.appendChild(style);
      document.documentElement.dataset["penTheme"] = THEME_ID;
    } catch (err) {
        console.log("Apply theme error", err);
    }
  </script>

        
  <script type="text/javascript">
    try {
      const styles = getComputedStyle(document.documentElement);
      const themeColor = styles.getPropertyValue('--rt-colors-base-background-primary').trim();
      const meta = document.createElement('meta');
      meta.name = 'theme-color';
      meta.setAttribute('content', themeColor);
      document.head.appendChild(meta);
    } catch (err) {
        console.log("setThemeToMeta error", err);
    }
  </script>

